DB_NAME=quinuapata_db
DB_USER=expressadmin
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_URL=jdbc:postgresql://postgres:5432/quinuapata_db
JWT_SECRET=CHANGE_ME_minimum_32_characters_random_secret_key_here
JWT_EXPIRATION=86400000
ALLOWED_ORIGINS=http://localhost:3000
POSTGRES_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Frontend (URL visible desde el navegador del cliente)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Dominio del servidor (para Nginx + Certbot SSL)
DOMAIN=tudominio.com

# Backup automático de PostgreSQL
BACKUP_RETENTION_DAYS=30
# Opcional: copiar backups a un destino remoto (rclone o rsync)
# RCLONE_REMOTE=gdrive:expressvraem-backups
# BACKUP_RSYNC_DEST=user@servidor:/backups/expressvraem
