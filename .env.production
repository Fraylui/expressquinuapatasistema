# ============================================================
# Express Quinuapata VRAEM SAC — Variables de Producción
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo como .env en el servidor de producción
#   2. Reemplaza TODOS los valores marcados con <CAMBIAR_...>
#   3. NUNCA subas este archivo con valores reales a Git
#   4. Para generar JWT_SECRET:  openssl rand -base64 64
#   5. Para generar DB_PASSWORD: openssl rand -base64 24
# ============================================================

# ── Base de datos ────────────────────────────────────────────
DB_NAME=quinuapata_pdn
DB_USER=expressadmin_pdn
DB_PASSWORD=<CAMBIAR_PASSWORD_MUY_SEGURA_MIN_20_CHARS>

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=<CAMBIAR_JWT_SECRET_MIN_64_CHARS_openssl_rand_base64_64>
JWT_EXPIRATION=86400000

# ── Dominio y SSL ────────────────────────────────────────────
# DOMAIN: solo el nombre del dominio, sin https:// ni barra
# Ejemplos: quinuapata.com   sistema.quinuapata.com   192.168.1.100
DOMAIN=<TU_DOMINIO_O_IP>

# Email para notificaciones de expiración de certificado Let's Encrypt
CERTBOT_EMAIL=<EMAIL_DEL_ADMINISTRADOR>

# ── URLs de la aplicación (con HTTPS una vez configurado SSL) ─
# Antes de SSL:   http://${DOMAIN}
# Después de SSL: https://${DOMAIN}
ALLOWED_ORIGINS=https://<TU_DOMINIO_O_IP>
NEXT_PUBLIC_API_URL=https://<TU_DOMINIO_O_IP>
NEXT_PUBLIC_WS_URL=wss://<TU_DOMINIO_O_IP>

# ── Email (opcional — dejar en blanco si no usas notificaciones) ─
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
