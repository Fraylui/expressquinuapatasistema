# Normalizar finales de línea: LF en el repo, conversión automática en checkout Windows
* text=auto eol=lf

# Archivos binarios — sin conversión
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.zip binary
*.gz binary

# Scripts de shell — siempre LF (se ejecutan en Linux/Docker)
*.sh text eol=lf
*.sh linguist-language=Shell
